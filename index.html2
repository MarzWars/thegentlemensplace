    </header>

    <div class="features-grid" role="list">
      <article class="feature-card reveal delay-1" role="listitem">
        <svg class="card-icon" viewBox="0 0 52 52" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <!-- Champagne glasses toasting - sophistication & celebration -->
          <path d="M16 8 L18 20 Q18 24 20 26 L20 36 L16 36 M20 26 L22 26" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M36 8 L34 20 Q34 24 32 26 L32 36 L36 36 M32 26 L30 26" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M14 8 L20 8 M32 8 L38 8" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
          <circle cx="18" cy="12" r="1.5" fill="currentColor" opacity="0.6"/>
          <circle cx="34" cy="12" r="1.5" fill="currentColor" opacity="0.6"/>
