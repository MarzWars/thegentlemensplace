          <path d="M26 16 Q24 14 22 15 Q21 16 22 17 Q23 18 24 17" stroke="currentColor" stroke-width="1" fill="currentColor" opacity="0.3"/>
          <path d="M26 16 Q26 13 28 12 Q29 12 29 13 Q29 14 28 14" stroke="currentColor" stroke-width="1" fill="currentColor" opacity="0.2"/>
          <circle cx="26" cy="16" r="2" stroke="currentColor" stroke-width="1" fill="currentColor" opacity="0.4"/>
          <path d="M20 22 Q18 20 16 22 Q15 24 16 26 Q18 27 20 26" stroke="currentColor" stroke-width="1" opacity="0.5"/>
          <path d="M32 22 Q34 20 36 22 Q37 24 36 26 Q34 27 32 26" stroke="currentColor" stroke-width="1" opacity="0.5"/>
        </svg>
