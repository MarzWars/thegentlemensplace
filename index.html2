          <path d="M10 22 Q10 16 16 14 Q20 13 26 13 Q32 13 36 14 Q42 16 42 22 Q42 26 38 28 Q36 29 34 28 Q32 27 32 24 M20 28 Q18 29 16 28 Q12 26 10 22" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
