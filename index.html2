  <a href="#newsletter" class="nav-cta">Enter the Chamber</a>
  <button class="nav-hamburger" id="hamburger" aria-label="Open menu" aria-expanded="false">
    <span></span><span></span><span></span>
  </button>
</nav>

<!-- Mobile Drawer -->
