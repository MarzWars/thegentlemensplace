<section id="newsletter" aria-labelledby="nl-heading">
  <div class="newsletter-inner">

    <p class="section-eyebrow reveal" style="justify-content:center;">Founding Members</p>
    <h2 id="nl-heading" class="section-heading reveal delay-1">
      Secure Your Place at<br><em>The Table</em>
    </h2>
    <p class="section-body reveal delay-2" style="margin:0 auto 2rem; text-align:center; max-width:480px;">
      Founding members receive exclusive early access, a lifetime of curated privileges, and an
      invitation to the inaugural gathering — by invitation only.
    </p>

    <form id="nl-form" class="newsletter-form reveal delay-3" novalidate aria-label="Newsletter signup">
      <label for="nl-email" class="sr-only"></label>
      <input
        type="email"
        id="nl-email"
        class="newsletter-input"
        placeholder="Your email address"
        autocomplete="email"
        required
        aria-required="true"
      />
      <button type="submit" class="newsletter-btn" aria-label="Request invitation">
        <span class="btn-shimmer" aria-hidden="true"></span>
        Request Invitation
      </button>
    </form>

    <div id="nl-success" class="newsletter-success" role="status" aria-live="polite">
      <span class="success-icon" aria-hidden="true">◆</span>
      <span class="success-text">Your invitation has been noted, Gentleman.</span>
      <span style="font-size:0.6rem;letter-spacing:0.25em;text-transform:uppercase;color:var(--gold-dim);">We'll be in touch.</span>
    </div>

    <span class="newsletter-note reveal delay-4">Your privacy is absolute. No spam. No compromise.</span>

  </div>
</section>

