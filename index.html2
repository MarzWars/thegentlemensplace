  <meta name="robots" content="index, follow" />
  <meta property="og:title" content="The Gentleman's Place — Coming Soon" />
  <meta property="og:description" content="The ultimate European destination for discreet sensual chat and forbidden fantasies" />
  <meta property="og:type" content="website" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="assets/css/main.css" />
</head>
<body>

<!-- CUSTOM CURSOR -->
<div id="cursor"></div>
<div id="cursor-ring"></div>

<!-- PRELOADER -->
<div id="preloader" role="status" aria-label="Loading">
  <div class="preloader-crest">
    <div class="preloader-line">Est. MMXXV</div>
    <div class="preloader-monogram">GC</div>
    <div class="preloader-line">The Gentleman's Place</div>
  </div>
  <div class="preloader-bar-wrap">
    <div class="preloader-bar"></div>
  </div>
  <div class="preloader-pct">0%</div>
</div>

<!-- NAVIGATION -->
<nav id="navbar" role="navigation" aria-label="Main navigation">
  <a href="#hero" class="nav-logo" aria-label="The Gentleman's Place home">
    <span class="nav-logo-mark" aria-hidden="true">GC</span>
    The Gentleman's Place
  </a>
  <ul class="nav-links" role="list">
    <li><a href="#vision">Our World</a></li>
