<!-- HERO -->
<section id="hero" role="banner">
  <div class="hero-bg-base" aria-hidden="true"></div>
  <div class="hero-texture"  aria-hidden="true"></div>

  <!-- Parallax ornaments kept for luxury feel -->

  <div class="hero-content">
    <span class="hero-eyebrow" aria-label="Established 2025">Established MMXXV • Europe</span>

    <h1 class="hero-title">
      Something <em>Seductive</em><br>is Coming
    </h1>

    <p class="hero-subtitle">
      Where refined European elegance meets your deepest fantasies and most intimate desires.
    </p>

    <div class="gold-divider">
      <span class="gold-divider-diamond" aria-hidden="true"></span>
    </div>
  </div>

  <div class="hero-scroll-cue" aria-hidden="true">
    <span class="scroll-cue-text">Discover More</span>
    <span class="scroll-cue-line"></span>
  </div>
</section>

<!-- COUNTDOWN TIMER -->
<section id="countdown" aria-label="Launch countdown timer">
  <div class="countdown-label">The Chamber Opens In</div>
  <div class="countdown-grid" role="timer" aria-live="off">
    <div class="countdown-unit reveal">
      <span class="countdown-value"><span id="cd-days" class="digit">00</span></span>
      <span class="countdown-key">Days</span>
    </div>
    <span class="countdown-sep" aria-hidden="true">:</span>
    <div class="countdown-unit reveal delay-1">
      <span class="countdown-value"><span id="cd-hours" class="digit">00</span></span>
      <span class="countdown-key">Hours</span>
    </div>
    <span class="countdown-sep" aria-hidden="true">:</span>
    <div class="countdown-unit reveal delay-2">
      <span class="countdown-value"><span id="cd-minutes" class="digit">00</span></span>
      <span class="countdown-key">Minutes</span>
    </div>
    <span class="countdown-sep" aria-hidden="true">:</span>
    <div class="countdown-unit reveal delay-3">
      <span class="countdown-value"><span id="cd-seconds" class="digit">00</span></span>
      <span class="countdown-key">Seconds</span>
    </div>
  </div>
</section>

<!-- VISION SECTION -->
<section id="vision" aria-labelledby="vision-heading">
  <div class="section-inner vision-layout">
    <div class="vision-text-col">
      <p class="section-eyebrow reveal">Our Philosophy</p>
      <h2 id="vision-heading" class="section-heading reveal delay-1">
        For Gentlemen Who<br><em>Crave More</em>
      </h2>
      <p class="section-body reveal delay-2">
        The Gentleman's Place is Europe's most exclusive sensual chat destination — created for the discerning man who appreciates beauty, seduction, and the thrill of intimate conversation without limits.
      </p>
      <p class="section-body reveal delay-3" style="margin-top:1.25rem;">
        Discreet. Sophisticated. Unforgettable. Connect with elegant, open-minded women who know exactly how to fulfill your fantasies in complete privacy.
      </p>
      <div class="vision-quote reveal delay-4">
        <blockquote>
          "A true gentleman knows that the most exquisite pleasures are those shared in confidence."
        </blockquote>
        <cite>— The Gentleman's Place Manifesto</cite>
      </div>
    </div>

    <div class="vision-image-col reveal-right">
      <div class="vision-frame">
        <!-- Crest kept (looks elegant) -->
        <svg class="vision-svg-art" viewBox="0 0 360 360" fill="none" xmlns="http://www.w3.org/2000/svg" aria-label="The Gentleman's Place crest">
          <!-- (SVG unchanged - still looks luxurious) -->
          <circle cx="180" cy="180" r="160" stroke="#C9A84C" stroke-width="0.8" opacity="0.3"/>
          <circle cx="180" cy="180" r="150" stroke="#C9A84C" stroke-width="1.5" opacity="0.6"/>
          <circle cx="180" cy="180" r="138" stroke="#C9A84C" stroke-width="0.5" opacity="0.25"/>
          <path id="topArc" d="M 68 180 A 112 112 0 0 1 292 180" fill="none"/>
          <text font-family="Playfair Display, serif" font-size="11" fill="#C9A84C" letter-spacing="5" opacity="0.8">
            <textPath href="#topArc" startOffset="9%">THE GENTLEMAN'S PLACE</textPath>
          </text>
          <path id="botArc" d="M 70 185 A 110 110 0 0 0 290 185" fill="none"/>
          <text font-family="Montserrat, sans-serif" font-size="8" fill="#C9A84C" letter-spacing="7" opacity="0.55">
            <textPath href="#botArc" startOffset="13%">EUROPE • MMXXV</textPath>
          </text>
          <path d="M180 70 L235 95 L235 175 Q235 215 180 240 Q125 215 125 175 L125 95 Z" stroke="#C9A84C" stroke-width="1.2" fill="rgba(107,26,42,0.12)"/>
          <text x="180" y="175" font-family="Playfair Display, serif" font-size="52" font-weight="700" fill="#C9A84C" text-anchor="middle" dominant-baseline="middle" opacity="0.9">GC</text>
        </svg>
      </div>
    </div>
  </div>
</section>

<!-- FEATURES / OFFERINGS -->
<section id="features" aria-labelledby="features-heading">
  <div class="section-inner">
    <header class="features-header">
      <p class="section-eyebrow reveal">What Awaits You</p>
      <h2 id="features-heading" class="section-heading reveal delay-1">
        Four Pillars of<br><em>Sensual Pleasure</em>
