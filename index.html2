        <svg class="card-icon" viewBox="0 0 52 52" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <!-- Microphone with sound waves - voice, intimacy, audio -->
          <rect x="22" y="12" width="8" height="14" rx="4" stroke="currentColor" stroke-width="1.2"/>
          <path d="M16 24 Q16 30 26 32 Q36 30 36 24" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
          <path d="M26 32 L26 38 M20 38 L32 38" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
          <path d="M38 18 Q40 18 40 20" stroke="currentColor" stroke-width="1" stroke-linecap="round" opacity="0.5"/>
          <path d="M40 18 Q42 18 42 20" stroke="currentColor" stroke-width="1" stroke-linecap="round" opacity="0.4"/>
          <path d="M38 24 Q40 24 40 26" stroke="currentColor" stroke-width="1" stroke-linecap="round" opacity="0.5"/>
          <path d="M40 24 Q42 24 42 26" stroke="currentColor" stroke-width="1" stroke-linecap="round" opacity="0.4"/>
